TOKEN_INDEX_SESSION_SECRET=change-me-session-secret #随便
# LinuxDo OAuth2 配置 https://connect.linux.do/dash/sso
TOKEN_INDEX_LINUXDO_CLIENT_ID= #Client ID
TOKEN_INDEX_LINUXDO_CLIENT_SECRET= #Client Secret 
TOKEN_INDEX_LINUXDO_REDIRECT_URI=http://127.0.0.1:8000/auth/linuxdo/callback #回调地址，需与 LinuxDo SSO 配置中的回调地址一致
TOKEN_INDEX_LINUXDO_SCOPE=read #权限范围，保持默认即可
TOKEN_INDEX_LINUXDO_MIN_TRUST_LEVEL=0 #最低信任等级，0 表示不限制，1 表示至少需要信任等级 1，依此类推
TOKEN_INDEX_LINUXDO_ALLOWED_IDS= #允许登录的 LinuxDo 用户 ID 列表，逗号分隔，留空表示允许所有用户
TOKEN_INDEX_ADMIN_IDENTITIES= #后台管理员列表，支持 LinuxDo ID 或 @用户名，逗号分隔

# 数据库路径（默认 ./token_atlas.db）
TOKEN_DB_PATH=

# 领取额度与分发规则
# 令牌状态阈值
TOKEN_HEALTHY_THRESHOLD=1000 #健康状态的令牌数量阈值
TOKEN_WARNING_THRESHOLD=500 #警告状态的令牌数量阈值
TOKEN_CRITICAL_THRESHOLD=100 #严重状态的令牌数量阈值

# 监控指标阈值
TOKEN_HOURLY_LIMIT_HEALTHY=30 #每小时领取总额度健康状态的阈值
TOKEN_HOURLY_LIMIT_WARNING=20 #每小时领取总额度警告状态的阈值
TOKEN_HOURLY_LIMIT_CRITICAL=15 #每小时领取总额度严重状态的阈值
TOKEN_MAX_CLAIMS_HEALTHY=1 #每个令牌的最大领取次数健康状态的阈值
TOKEN_MAX_CLAIMS_WARNING=2 #每个令牌的最大领取次数警告状态的阈值
TOKEN_MAX_CLAIMS_CRITICAL=3 #每个令牌的最大领取次数严重状态的阈值
 #每个令牌的最大领取次数
TOKEN_APIKEY_MAX_PER_USER=5 #每个用户的最大 API Key 数量限制
TOKEN_APIKEY_RATE_LIMIT_PER_MINUTE=60 #@每个 API Key 每分钟的请求限制

# 服务地址
TOKEN_PROVIDER_BASE_URL=http://127.0.0.1:8000 #服务的基础 URL
PORT=8000 #服务监听的端口
