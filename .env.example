TOKEN_INDEX_SESSION_SECRET=change-me-session-secret #随便
# LinuxDo OAuth2 配置 https://connect.linux.do/dash/sso
TOKEN_INDEX_LINUXDO_CLIENT_ID= #Client ID
TOKEN_INDEX_LINUXDO_CLIENT_SECRET= #Client Secret 
TOKEN_INDEX_LINUXDO_REDIRECT_URI=http://127.0.0.1:8000/auth/linuxdo/callback #回调地址，需与 LinuxDo SSO 配置中的回调地址一致
TOKEN_INDEX_LINUXDO_SCOPE=read #权限范围，保持默认即可
TOKEN_INDEX_LINUXDO_MIN_TRUST_LEVEL=0 #最低信任等级，0 表示不限制，1 表示至少需要信任等级 1，依此类推
TOKEN_INDEX_LINUXDO_ALLOWED_IDS= #允许登录的 LinuxDo 用户 ID 列表，逗号分隔，留空表示允许所有用户
TOKEN_INDEX_ADMIN_IDENTITIES= #后台管理员列表，支持 LinuxDo ID 或 @用户名，逗号分隔

# 数据库路径（默认 ./token_atlas.db）
TOKEN_DB_PATH=
# Token 文件目录（默认项目根目录下的 token）
TOKEN_FILES_DIR=token

# 缓存配置
TOKEN_CACHE_BACKEND=auto # auto=优先 Redis，失败时回退内存；redis=强制尝试 Redis；memory=仅内存
TOKEN_REDIS_URL=redis://127.0.0.1:6379/0 # Redis 服务器地址
TOKEN_REDIS_USERNAME= # Redis 用户名，未启用 ACL 可留空
TOKEN_REDIS_PASSWORD= # Redis 密码，建议用这个而不是把密码直接写进 URL
TOKEN_REDIS_PREFIX=token_index: # Redis 键前缀，避免与其他应用冲突
TOKEN_CACHE_DEFAULT_TTL_SEC=3600 # 默认缓存 TTL，当前版本主要作为通用预留项
TOKEN_CACHE_ME_TTL_SEC=3600 # /me 与 /me/bootstrap 相关缓存 TTL，单位秒
TOKEN_CACHE_CLAIMS_TTL_SEC=3600 # /claims 与下载相关缓存 TTL，单位秒
TOKEN_CACHE_ADMIN_TTL_SEC=3600 # /admin 接口缓存 TTL，单位秒
TOKEN_CACHE_QUEUE_TTL_SEC=86400 # 队列快照缓存 TTL，实时变化主要依赖事件推送与主动失效刷新
TOKEN_CACHE_DASHBOARD_TTL_SEC=3600 # /dashboard 接口缓存 TTL，单位秒

# 领取额度与分发规则
# 令牌状态阈值
TOKEN_HEALTHY_THRESHOLD=1000 #健康状态的令牌数量阈值
TOKEN_WARNING_THRESHOLD=500 #警告状态的令牌数量阈值
TOKEN_CRITICAL_THRESHOLD=100 #严重状态的令牌数量阈值

# 监控指标阈值
TOKEN_HOURLY_LIMIT_HEALTHY=30 #每小时领取总额度健康状态的阈值
TOKEN_HOURLY_LIMIT_WARNING=20 #每小时领取总额度警告状态的阈值
TOKEN_HOURLY_LIMIT_CRITICAL=15 #每小时领取总额度严重状态的阈值
TOKEN_MAX_CLAIMS_HEALTHY=1 #每个令牌的最大领取次数健康状态的阈值
TOKEN_MAX_CLAIMS_WARNING=2 #每个令牌的最大领取次数警告状态的阈值
TOKEN_MAX_CLAIMS_CRITICAL=3 #每个令牌的最大领取次数严重状态的阈值
TOKEN_NON_HEALTHY_MAX_CLAIMS_SCOPE=all_unfinished 
# 非健康状态放开范围：all_unfinished=所有未领齐账号，new_only=仅状态后新账号，unclaimed_only=仅未领取账号
# 每个令牌的最大领取次数
TOKEN_APIKEY_MAX_PER_USER=5 #每个用户的最大 API Key 数量限制
TOKEN_APIKEY_RATE_LIMIT_PER_MINUTE=60 #@每个 API Key 每分钟的请求限制
TOKEN_CODEX_PROBE_DELAY_SEC=0.1 #Codex 探活队列的请求间隔（秒）
TOKEN_CODEX_PROBE_TIMEOUT_SEC=20 #Codex 探活请求超时（秒）
TOKEN_CODEX_PROBE_RESERVE_SEC=30 #账号探活预留锁的保留时间（秒）
TOKEN_UPLOAD_MAX_FILES_PER_REQUEST=10 #单次最多上传多少个 JSON 文件
TOKEN_UPLOAD_MAX_FILE_SIZE_BYTES=10240 #单个 JSON 最大体积（字节）
TOKEN_UPLOAD_MAX_SUCCESS_PER_HOUR=20 #每个用户每小时最多成功上传多少个账号

# 服务地址
TOKEN_PROVIDER_BASE_URL=http://127.0.0.1:8000 #服务的基础 URL
PORT=8000 #服务监听的端口
